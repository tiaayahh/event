# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=event_planner_db
DB_USER=root
DB_PASS=1234

# SMTP mail (PHPMailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password-or-app-password
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME=Planora

# Daraja (optional if using M-Pesa flows)
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=
DARAJA_ENV=sandbox
# Optional: in sandbox, override charge amount to a small test value (e.g. 1)
DARAJA_SANDBOX_TEST_AMOUNT=1
DARAJA_TIMEOUT_SECONDS=30
DARAJA_CALLBACK_TOKEN=
DARAJA_ALLOWED_IPS=
# Set to 0 to disable manual M-Pesa code confirmation fallback and rely only on callback
DARAJA_ALLOW_MANUAL_CONFIRM=1
# Optional: path to CA bundle PEM used by PHP cURL if your network proxies TLS
# DARAJA_CURL_CA_BUNDLE=C:/path/to/cacert.pem
